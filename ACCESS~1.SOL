pragma solidity ^0.8.20;

import "@openzeppelin/contracts/access/AccessControl.sol" as OZAccessControl;

contract AccessControl is OZAccessControl.AccessControl {
    bytes32 public constant EXECUTIVE_ROLE = keccak256("EXECUTIVE_ROLE");
    bytes32 public constant OPERATOR_ROLE = keccak256("OPERATOR_ROLE");

    event AdministrativeRoleAssigned(bytes32 indexed role, address indexed account);

    constructor() {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(EXECUTIVE_ROLE, msg.sender);
    }

    function grantPlatformRole(bytes32 role, address account) external onlyRole(DEFAULT_ADMIN_ROLE) {
        _grantRole(role, account);
        emit AdministrativeRoleAssigned(role, account);
    }

    function revokePlatformRole(bytes32 role, address account) external onlyRole(DEFAULT_ADMIN_ROLE) {
        _revokeRole(role, account);
    }
}